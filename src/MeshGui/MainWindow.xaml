<Window x:Class="MeshGui.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CSiBridge Custom Mesher V4" SizeToContent="Height" Width="600" WindowStyle="ToolWindow" Background="#FFFFFF"
        Topmost="{Binding ElementName=chkTopmost, Path=IsChecked}">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,10">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Text="Generador de Malla Ray-Slicing V5" FontWeight="Bold" FontSize="16" HorizontalAlignment="Center" Grid.Column="0"/>
            <CheckBox x:Name="chkTopmost" Content="Siempre al frente" IsChecked="True" VerticalAlignment="Center" Grid.Column="1"/>
        </Grid>

        <Button x:Name="BtnConnect" Content="1. Conectar a CSiBridge" Grid.Row="1" Margin="0,0,0,10" Padding="8" Click="BtnConnect_Click" FontWeight="Bold" Background="#FF2D2D30" Foreground="White" BorderThickness="0"/>

        <GroupBox Header="1. Estrategia de Captura (Seleccionar en CSiBridge primero)" Grid.Row="2" Padding="10" Background="White" BorderBrush="#FFCCCCCC">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="5"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button x:Name="BtnCaptureArea" Content="Capturar Área" Padding="8" Background="#FFE6F2FF" BorderBrush="#FF007ACC" Click="BtnCaptureArea_Click" IsEnabled="False" Grid.Column="0"/>
                    <Button x:Name="BtnCapturePoints" Content="Capturar 3-4 Nudos" Padding="8" Background="#FFF5F5F5" BorderBrush="#FFCCCCCC" Click="BtnCapturePoints_Click" IsEnabled="False" Grid.Column="2"/>
                </Grid>
                
                <DataGrid x:Name="DgPoints" Height="120" Margin="0,10,0,0" AutoGenerateColumns="False" IsReadOnly="True" HeadersVisibility="Column" Background="White" RowBackground="#FFFDFDFD" AlternatingRowBackground="#FFF5F5F5">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Ref" Binding="{Binding Name}" Width="60"/>
                        <DataGridTextColumn Header="X (m)" Binding="{Binding X, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="Y (m)" Binding="{Binding Y, StringFormat=F3}" Width="*"/>
                        <DataGridTextColumn Header="Z (m)" Binding="{Binding Z, StringFormat=F3}" Width="*"/>
                    </DataGrid.Columns>
                </DataGrid>
                <TextBlock x:Name="TxtCaptureMode" Text="Modo: Ninguno" FontStyle="Italic" Foreground="Gray" Margin="0,5,0,0"/>

                <Button x:Name="BtnDeleteInside" Content="1.5 Borrar Mallas Internas al Límite Capturado" Margin="0,10,0,0" Padding="6" Click="BtnDeleteInside_Click" Background="#FFFFE6E6" BorderBrush="#FFCC0000" Foreground="#FFCC0000" IsEnabled="False"/>
            </StackPanel>
        </GroupBox>

        <GroupBox Header="2. Configuraciones de Malla" Grid.Row="4" Padding="10" Margin="0,10,0,0" Background="White" BorderBrush="#FFCCCCCC">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                
                <TextBlock Text="dx (m): " VerticalAlignment="Center" Grid.Row="0" Grid.Column="0"/>
                <TextBox x:Name="TxtDx" Text="0.2" Width="50" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" Margin="5,0,0,0"/>

                <TextBlock Text="dy (m): " VerticalAlignment="Center" Grid.Row="0" Grid.Column="2" Margin="10,0,0,0"/>
                <TextBox x:Name="TxtDy" Text="0.2" Width="50" Grid.Row="0" Grid.Column="3" HorizontalAlignment="Left" Margin="5,0,0,0"/>

                <TextBlock Text="Snap Tol (%): " VerticalAlignment="Center" Grid.Row="1" Grid.Column="0" Margin="0,10,0,0"/>
                <TextBox x:Name="TxtTol" Text="50" Width="50" Grid.Row="1" Grid.Column="1" HorizontalAlignment="Left" Margin="5,10,0,0"/>

                <TextBlock Text="Directriz:" FontWeight="SemiBold" VerticalAlignment="Center" Grid.Row="2" Grid.Column="0" Margin="0,15,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Margin="5,15,0,0" VerticalAlignment="Center">
                    <RadioButton x:Name="RbHoriz" Content="Prioridad Horizontal" IsChecked="True" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RbVert" Content="Prioridad Vertical"/>
                </StackPanel>

                <TextBlock Text="Dibujo:" FontWeight="SemiBold" VerticalAlignment="Center" Grid.Row="3" Grid.Column="0" Margin="0,10,0,0"/>
                <StackPanel Orientation="Horizontal" Grid.Row="3" Grid.Column="1" Grid.ColumnSpan="3" Margin="5,10,0,0" VerticalAlignment="Center">
                    <RadioButton x:Name="RbAntiHorario" Content="Antihorario (Local 3 +)" IsChecked="True" Margin="0,0,15,0"/>
                    <RadioButton x:Name="RbHorario" Content="Horario (Local 3 -)"/>
                </StackPanel>
            </Grid>
        </GroupBox>
        
        <Button x:Name="BtnRun" Content="2. Ejecutar Mallado Ray-Slicing" Grid.Row="5" Margin="0,15,0,5" Padding="12" Click="BtnRun_Click" Background="#FF007ACC" Foreground="White" FontWeight="Bold" IsEnabled="False" BorderThickness="0"/>

        <TextBlock x:Name="TxtLog" Text="Esperando conexión..." Grid.Row="6" Margin="0,5,0,0" TextWrapping="Wrap" Foreground="#FF444444" FontSize="11"/>
    </Grid>
</Window>
